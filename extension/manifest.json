{
  "manifest_version": 3,
  "name": "沉浸式学习英语",
  "version": "1.0.0",
  "description": "按英语等级沉浸式替换中文网页中的词汇",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "沉浸式学习英语",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["injected.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["dict/graded_dict.json", "panel.html", "popup.css", "popup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
